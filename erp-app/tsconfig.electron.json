{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "dist-electron",
    "rootDir": "electron",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@electron/*": ["electron/*"]
    },
    "types": ["jest", "node"]
  },
  "include": ["electron/**/*"],
  "exclude": ["electron/**/*.test.ts", "electron/**/__tests__"]
}
