{
  "name": "erp-app",
  "version": "1.0.0",
  "description": "ERP Comptabilité & Facturation — Desktop App",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5174 && NODE_ENV=development VITE_PORT=5174 electron .\"",
    "postinstall": "electron-rebuild -f -w better-sqlite3 2>/dev/null || true",
    "build:renderer": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron && electron-builder",
    "preview": "vite preview",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "better-sqlite3": "^9.4.3",
    "date-fns": "^3.6.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "html2canvas": "^1.4.1",
    "i18next": "^23.10.0",
    "jspdf": "^2.5.1",
    "node-machine-id": "^1.1.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "react-i18next": "^14.1.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "jest": "^29.7.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.2",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "ma.erp.app",
    "productName": "ERP Pro",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
